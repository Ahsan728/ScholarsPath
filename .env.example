# ============================================================
# scholars.ahsansuny.com — Environment Variables
# Copy this to .env.local and fill in all values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ── Anthropic (Claude) ────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Pinecone ──────────────────────────────────────────────────
# Get from: https://app.pinecone.io/
# Free tier: 100k vectors, 1 index
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=scholars-opportunities
# Index settings: dimension=384 (all-MiniLM-L6-v2), metric=cosine

# ── HuggingFace ───────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Used for free sentence-transformers/all-MiniLM-L6-v2 embeddings
HUGGINGFACE_API_TOKEN=hf_...

# ── Brevo (Email) ─────────────────────────────────────────────
# Get from: https://app.brevo.com/settings/keys/api
# Free: 300 emails/day
BREVO_API_KEY=xkeysib-...

# ── Cron security ────────────────────────────────────────────
# Any random secret string — used to protect /api/alerts endpoint
# Generate: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Site URL (used in GitHub Actions) ────────────────────────
SITE_URL=https://scholars.ahsansuny.com
